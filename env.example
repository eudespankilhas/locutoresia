# Variáveis de ambiente para Locutores IA
# Configure estas variáveis no painel da Vercel (Settings > Environment Variables)

# Supabase Local (banco de dados do projeto)
SUPABASE_URL=https://sua-url.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon
SUPABASE_SERVICE_KEY=sua-chave-service-role

# Supabase NewPost-IA (banco de dados da rede social)
NEWPOST_SUPABASE_URL=https://ykswhzqdjoshjoaruhqs.supabase.co
NEWPOST_SUPABASE_SERVICE_KEY=sua-chave-service-role
NEWPOST_SUPABASE_ANON_KEY=sua-chave-anon
NEWPOST_AUTHOR_ID=3a1a93d0-e451-47a4-a126-f1b7375895eb

# Gemini API (para geração de conteúdo)
GEMINI_API_KEY=sua-chave-gemini

# Google AI Studio
GOOGLE_AI_STUDIO_API_KEY=sua-chave-google-ai

# ElevenLabs (para clonagem de voz)
ELEVENLABS_API_KEY=sua-chave-elevenlabs

# Ambiente
FLASK_ENV=production
VERCEL=1
