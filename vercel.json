{
  "name": "locutores-ia",
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "backend/app.py"
    },
    {
      "source": "/(.*)",
      "destination": "backend/app.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "VERCEL": "1"
  },
  "functions": {
    "backend/app.py": {
      "maxDuration": 30
    }
  }
}
