# Chave de API do Google Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui

# Chave de API do Google AI Studio para geração de vozes
# Configure como variável de ambiente no Vercel: GOOGLE_AI_STUDIO_API_KEY
GOOGLE_AI_STUDIO_API_KEY=sua_chave_google_ai_studio_aqui

# Chave de API do ElevenLabs (para clonagem de voz)
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui

# Configurações do Flask
FLASK_ENV=development
FLASK_DEBUG=True
