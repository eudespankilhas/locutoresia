        // ===== FUNÇÕES DE AÇÃO PARA PUBLICAÇÕES =====
        
        function editPublication(id, encodedTitle, encodedContent) {
            const title = decodeURIComponent(encodedTitle);
            const content = decodeURIComponent(encodedContent);
            
            // Criar modal de edição
            const modal = document.createElement('div');
            modal.id = 'edit-modal';
            modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); display: flex; align-items: center; justify-content: center; z-index: 1000;';
            modal.innerHTML = `
                <div style="background: #1e293b; padding: 24px; border-radius: 12px; max-width: 500px; width: 90%; max-height: 80vh; overflow-y: auto;">
                    <h3 style="color: white; margin-bottom: 16px;">✏️ Editar Publicação</h3>
                    <div style="margin-bottom: 12px;">
                        <label style="color: #94a3b8; font-size: 12px; display: block; margin-bottom: 4px;">Título</label>
                        <input type="text" id="edit-title" value="${title.replace(/"/g, '&quot;')}" style="width: 100%; padding: 8px; background: #334155; border: 1px solid #475569; border-radius: 4px; color: white; font-size: 13px;">
                    </div>
                    <div style="margin-bottom: 16px;">
                        <label style="color: #94a3b8; font-size: 12px; display: block; margin-bottom: 4px;">Conteúdo</label>
                        <textarea id="edit-content" rows="6" style="width: 100%; padding: 8px; background: #334155; border: 1px solid #475569; border-radius: 4px; color: white; font-size: 13px; resize: vertical;">${content}</textarea>
                    </div>
                    <div style="display: flex; gap: 8px; justify-content: flex-end;">
                        <button onclick="closeEditModal()" style="background: #64748b; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer;">Cancelar</button>
                        <button onclick="saveEdit('${id}')" style="background: #3b82f6; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer;">Salvar Alterações</button>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);
            addLog(`✏️ Editando publicação ${id}`, 'info');
        }
        
        function closeEditModal() {
            const modal = document.getElementById('edit-modal');
            if (modal) modal.remove();
        }
        
        async function saveEdit(id) {
            const title = document.getElementById('edit-title').value;
            const content = document.getElementById('edit-content').value;
            
            try {
                const response = await fetch(`${API_BASE}/api/publications/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, content })
                });
                
                if (response.ok) {
                    addLog(`✅ Publicação ${id} atualizada!`, 'success');
                    closeEditModal();
                    loadPublications();
                } else {
                    throw new Error('Erro ao atualizar');
                }
            } catch (error) {
                addLog(`❌ Erro ao salvar: ${error.message}`, 'error');
            }
        }
        
        async function savePublication(id) {
            try {
                const response = await fetch(`${API_BASE}/api/publications/${id}/save`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    addLog(`💾 Publicação ${id} salva!`, 'success');
                } else {
                    throw new Error('Erro ao salvar');
                }
            } catch (error) {
                addLog(`❌ Erro: ${error.message}`, 'error');
            }
        }
        
        async function approvePublication(id) {
            try {
                const response = await fetch(`${API_BASE}/api/publications/${id}/approve`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    addLog(`✓ Publicação ${id} aprovada!`, 'success');
                    loadPublications();
                } else {
                    throw new Error('Erro ao aprovar');
                }
            } catch (error) {
                addLog(`❌ Erro: ${error.message}`, 'error');
            }
        }
        
        async function postToNewPostIA(id, encodedTitle, encodedContent, imageUrl) {
            const title = decodeURIComponent(encodedTitle);
            const content = decodeURIComponent(encodedContent);
            
            try {
                addLog(`🚀 Postando ${id} na NewPost-IA...`, 'info');
                
                const response = await fetch(`${API_BASE}/api/newpost/publish`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        title: title,
                        content: content,
                        image_url: imageUrl,
                        hashtags: ['notícia', 'Brasil'],
                        source_id: id
                    })
                });
                
                const result = await response.json();
                
                if (response.ok && result.success) {
                    addLog(`✅ Postado com sucesso! ID: ${result.post_id}`, 'success');
                    // Atualizar status na lista
                    await approvePublication(id);
                } else {
                    throw new Error(result.error || 'Erro ao publicar');
                }
            } catch (error) {
                addLog(`❌ Erro ao postar: ${error.message}`, 'error');
            }
        }
