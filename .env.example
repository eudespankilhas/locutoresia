# Chave de API do Google Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui

# Chave de API do Google AI Studio para geração de vozes
# Configure como variável de ambiente no Vercel: GOOGLE_AI_STUDIO_API_KEY
GOOGLE_AI_STUDIO_API_KEY=sua_chave_google_ai_studio_aqui

# Chave de API do ElevenLabs (para clonagem de voz)
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui

# Configurações do Supabase
SUPABASE_URL=sua_url_supabase_aqui
SUPABASE_ANON_KEY=sua_chave_anon_supabase_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_supabase_aqui
SUPABASE_SERVICE_KEY=sua_chave_service_supabase_aqui

# Configurações do Flask
FLASK_ENV=development
FLASK_DEBUG=True

# Configurações do NewPost-IA
NEWPOST_SUPABASE_URL=https://sua-url-newpost.supabase.co
NEWPOST_SUPABASE_ANON_KEY=sua-chave-anon-newpost-aqui
